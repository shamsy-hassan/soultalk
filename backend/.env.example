# Email transport: auto | smtp | resend_http
# - auto: try Resend HTTP first, then SMTP fallback
# - smtp: only SMTP (best for local dev + Mailpit/MailHog/Gmail)
# - resend_http: only Resend HTTP (best for many hosted environments)
EMAIL_TRANSPORT=auto

# --- Resend (HTTP) ---
RESEND_API_KEY=
# Must be a verified sender/domain in production. For Resend test mode, you can use:
# RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_EMAIL=

# --- SMTP ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ADDRESS=
EMAIL_FROM_ADDRESS=
EMAIL_PASSWORD=

# TLS toggles (optional)
# EMAIL_USE_SSL=false
# EMAIL_STARTTLS=true
# EMAIL_FALLBACK_PORTS=587,465

# OTP settings
OTP_EXPIRY_MINUTES=5
